{
  "name": "cocos-mcp",
  "version": "0.1.0",
  "description": "MCP bridge for Cocos Creator 2.4 — exposes editor/scene/asset operations to AI assistants over WebSocket.",
  "author": "cocosMcp",
  "main": "main.js",
  "scene-script": "scene-script.js",
  "main-menu": {
    "扩展/Cocos MCP/打开面板": {
      "message": "cocos-mcp:open-panel"
    },
    "扩展/Cocos MCP/启动 Bridge": {
      "message": "cocos-mcp:start-bridge"
    },
    "扩展/Cocos MCP/停止 Bridge": {
      "message": "cocos-mcp:stop-bridge"
    },
    "扩展/Cocos MCP/查看状态": {
      "message": "cocos-mcp:status"
    }
  },
  "panel": {
    "main": "panel/index.js",
    "type": "dockable",
    "title": "Cocos MCP",
    "width": 420,
    "height": 360
  },
  "dependencies": {
    "ws": "^8.13.0"
  }
}
